# ═══════════════════════════════════════════════════════════════
# DrawingAI Lite — Configuration Template
# ═══════════════════════════════════════════════════════════════
# העתק קובץ זה ל-.env ומלא את הערכים שלך.
# אסור להעלות .env ל-GitHub! (הוא ב-gitignore)

# ─── בחירת מודל פעיל ───
# "gpt-4o-vision" = Azure OpenAI GPT-4o (ברירת מחדל)
# "gpt-5.4"       = Azure OpenAI GPT-5.4 (reasoning model)
# ניתן לעקוף דרך ה-UI: סרגל ⚙️ הגדרות מודל → output/_runtime_settings.json
ACTIVE_MODEL=gpt-4o-vision

# ─── Azure OpenAI — GPT-4o / Vision ───
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_DEPLOYMENT_NAME=gpt-4o

# ─── GPT-5.4 (Reasoning) ───
MODEL_GPT_5_4_ENDPOINT=https://your-resource.openai.azure.com/
MODEL_GPT_5_4_API_KEY=your-api-key-here
MODEL_GPT_5_4_API_VERSION=2024-12-11-preview
MODEL_GPT_5_4_DEPLOYMENT=gpt-5.4
MODEL_GPT_5_4_IS_REASONING=true

# ─── תוספת Azure על מחירי OpenAI הרשמיים ───
# 1.10 = +10% | 1.20 = +20% (Regional / Data Residency)
AZURE_SURCHARGE=1.20

# ─── נתיב לקובץ Masters.xlsx ───
# אם לא מוגדר, ברירת המחדל היא: <root>/Masters.xlsx
# דוגמאות:
#   MASTERS_XLSX_PATH=C:\Data\Masters.xlsx
#   MASTERS_XLSX_PATH=/mnt/shared/Masters.xlsx
#   MASTERS_XLSX_PATH=D:\Projects\Masters.xlsx
MASTERS_XLSX_PATH=

# ─── Drawing Cache ───
# לכיבוי ה-cache (שימושי לבדיקה): הגדר ל-true
# ברירת מחדל: false (cache מופעל)
DRAWING_CACHE_DISABLED=false

# ─── OCR (Tesseract) ───
# נתיב לתיקיית Tesseract (Windows בלבד)
# דוגמה: C:\Program Files\Tesseract-OCR
TESSERACT_PATH=

# ─── לוגים ───
# רמת loglevel: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
